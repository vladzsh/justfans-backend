# Database
DATABASE_URL=postgres://justfans:justfans@db:5432/justfans
POSTGRES_DB=justfans
POSTGRES_USER=justfans
POSTGRES_PASSWORD=justfans

# Redis
REDIS_URL=redis://redis:6379/0

# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Realtime thresholds
# How many seconds without a chatter reply is considered overdue
OVERDUE_SECONDS=120
# How many seconds after last heartbeat a chatter is considered offline
PRESENCE_GRACE_SECONDS=30
# How often the frontend sends ping (seconds)
HEARTBEAT_SECONDS=10
# Max messages per page
MESSAGES_PAGE_SIZE=30

# Frontend context (override for local build)
# FRONTEND_CONTEXT=../frontend

# Backend hostname as seen by nginx (override on Railway)
# BACKEND_HOST=backend
